# ─── Firefly III — variables d'environnement ──────────────────────────────
# MODÈLE versionné (sans secrets). Sur le Pi : `cp .env.example .env` puis
# remplir les vraies valeurs. Le .env n'est JAMAIS commité (cf. .gitignore).

# ── Application ──
APP_ENV=production
APP_DEBUG=false

# Clé de chiffrement — EXACTEMENT 32 caractères. À générer (cf. docs/firefly.md) :
#   head /dev/urandom | LC_ALL=C tr -dc 'A-Za-z0-9' | head -c 32 ; echo
APP_KEY=REMPLACER_PAR_32_CARACTERES_____

# URL publique : derrière nginx, en HTTPS, servie à la RACINE.
APP_URL=https://srv-cyber-infra.tail46bedb.ts.net
TZ=Europe/Paris
SITE_OWNER=jimmyhabre2004@gmail.com

# nginx termine le TLS puis relaie : Firefly doit FAIRE CONFIANCE au proxy pour
# lire X-Forwarded-Proto (sinon redirections HTTPS cassées). ** = réseau interne.
TRUSTED_PROXIES=**

# ── Base de données (PostgreSQL) ──
DB_CONNECTION=pgsql
DB_HOST=firefly-db          # = nom du conteneur db, résolu par le DNS Docker
DB_PORT=5432
DB_DATABASE=firefly
DB_USERNAME=firefly
# Mot de passe DB — à générer, ex. : openssl rand -base64 24
DB_PASSWORD=REMPLACER_PAR_UN_MDP_FORT

# ── Cron ──
# Token de déclenchement du cron — EXACTEMENT 32 caractères. À générer :
#   head /dev/urandom | LC_ALL=C tr -dc 'A-Za-z0-9' | head -c 32 ; echo
STATIC_CRON_TOKEN=REMPLACER_PAR_32_CARACTERES_____
